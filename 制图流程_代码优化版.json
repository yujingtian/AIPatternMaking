  "validation_steps": {
    "description": "接缝校验与闭合光顺（Walk Seams & Trueing）",
    "checks": [
      {
        "id": "INSEAM_MATCH",
        "name": "内缝长度匹配",
        "type": "CURVE_LENGTH",
        "curve_a": "back_panel.back_inseam_upper",
        "curve_b": "front_panel.front_inseam_upper",
        "target_diff": -1.0,
        "tolerance": 0.1,
        "action": "如果误差超出0.1cm，微调B4点Y坐标或F4点Y坐标"
      },
      {
        "id": "SIDE_SEAM_MATCH",
        "name": "侧缝长度匹配",
        "type": "CURVE_LENGTH",
        "curve_a": "back_panel.back_side_seam_upper",
        "curve_b": "front_panel.front_side_seam_upper",
        "target_diff": 0,
        "tolerance": 0.1,
        "action": "如果误差超出0.1cm，微调B7点或F7点"
      },
      {
        "id": "WAISTBAND_TOTAL",
        "name": "腰头总长验证",
        "type": "SUM_LENGTH",
        "segments": [
          "front_panel.front_waist",
          "back_panel.back_waist_temp",
          "yoke.after_rotation"
        ],
        "target": "Net_W",
        "tolerance": 0.1,
        "action": "如果误差超出0.1cm，调整育克省量"
      },
      {
        "id": "YOKE_MATCH",
        "name": "育克拼接长度匹配",
        "type": "CURVE_LENGTH",
        "curve_a": "yoke.lower_edge",
        "curve_b": "back_panel.upper_edge_after_yoke",
        "target_diff": 0,
        "tolerance": 0.05,
        "action": "强制光顺重绘，确保弧长相等"
      }
    ]
  },
  "shrinkage_compensation": {
    "description": "基于材质的选择性缩水率局部仿射变换",
    "materials": {
      "Shell": {
        "scale_x": "1 / (1 - Shell_Weft / 100)",
        "scale_y": "1 / (1 - Shell_Warp / 100)"
