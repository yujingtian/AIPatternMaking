  "code_implementation_notes": {
    "description": "代码实现参考",
    "curve_functions": {
      "BEZIER_CUBIC": "B(t) = (1-t)³P0 + 3(1-t)²tP1 + 3(1-t)t²P2 + t³P3, t∈[0,1]",
      "BEZIER_QUADRATIC": "B(t) = (1-t)²P0 + 2(1-t)tP1 + t²P2, t∈[0,1]",
      "SPLINE_CATMULL_ROM": "P(t) = 0.5*[2P1 + (-P0+P2)t + (2P0-5P1+4P2-P3)t² + (-P0+3P1-3P2+P3)t³]",
      "CURVE_LENGTH": "∫√(x'(t)² + y'(t)²)dt，数值积分或分段折线逼近"
    },
    "data_structures": [
      "Point: {x: float, y: float}",
      "Curve: {type: enum, points: Point[], control_points?: Point[]}",
      "PatternPiece: {name: string, points: Map<string,Point>, curves: Curve[]}"
    ],
    "algorithm_steps": [
      "1. 验证输入参数",
      "2. 按顺序计算中间变量",
      "3. 生成前裤片关键点",
      "4. 生成后裤片关键点",
      "5. 构建曲线（贝塞尔/样条）",
      "6. 育克分割与省量旋转",
      "7. 派生零部件",
      "8. 接缝校验与微调",
      "9. 缩水率补偿",
      "10. 添加缝份",
      "11. 生成剪口与标记",
      "12. DXF导出"
    ],
    "pitfalls": [
      "⚠️ 育克旋转后需要重新曲线光顺（Trueing）",
      "⚠️ 缩水率变换使用局部坐标系（纱向中心为原点）",
      "⚠️ 后内缝比前内缝短1cm用于缝制拉伸",
      "⚠️ 剪口深度不能超过缝份宽度的一半"
    ]
  }
